# Flask ayarlari
SECRET_KEY=your-secret-key-here
FLASK_DEBUG=false

# Ana Firebase (gelir/gider veritabani)
FIREBASE_DATABASE_URL=https://YOUR-PROJECT-default-rtdb.europe-west1.firebasedatabase.app
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_PROJECT",...}

# Lisans Firebase (lisans dogrulama)
LICENSES_FIREBASE_DATABASE_URL=https://YOUR-LICENSE-PROJECT-default-rtdb.firebaseio.com
LICENSES_FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_LICENSE_PROJECT",...}

# Lisans anahtari (EXE icin)
LICENSE_KEY=
